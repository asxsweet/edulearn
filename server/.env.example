# =============================================================================
# Render.com — backend (API) қалай іске қосу
# =============================================================================
# 1) render.com тіркеліп, жаңа PostgreSQL қосыңыз (New + PostgreSQL).
#    Дайын болғанда "Connections" → Internal Database URL-ді көшіріңіз.
#
# 2) New + Web Service: GitHub/GitLab репозиторийды таңдаңыз.
#    - Root Directory: server
#    - Build Command: npm install
#    - Start Command: npm start
#    - Instance: Free (немесе керек план)
#
# 3) Environment → Add Environment Variable:
#    DATABASE_URL = (1-қадамдағы PostgreSQL URL, postgres://...)
#    PGSSLMODE = require
#    NODE_ENV = production
#    JWT_SECRET = ұзын кездейсоқ жол (мысалы openssl rand -hex 32)
#    CLIENT_ORIGIN = Vercelдегі frontend түбі, мысалы https://edulearn.vercel.app
#                    Бірнеше origin керек болса, үтірмен жазыңыз:
#                    https://aicourseplatform.vercel.app,http://localhost:5173
#                    (соңында / жоқ; CORS үшін қажет)
#
# 4) Render-да PostgreSQL мен Web Service бір-біріне байланысты болуы: Web Service
#    "Environment" ішінде DATABASE_URL қойылғанда жеткілікті; Internal URL тек бір
#    региондағы сервистер үшін жұмыс істейді.
#
# 5) Deploy: Push немесе "Manual Deploy". API түбі: https://<service-name>.onrender.com
#    Frontend .env: VITE_API_URL=https://<service-name>.onrender.com
#
# Ескерту: Render Free Web Service "уқсайды" — 15 мин сонда сондықтан бірінші
# сұрау баяу болуы мүмкін; Production үшін Paid план қараңыз.
# =============================================================================

# PostgreSQL (local: docker compose up -d, then use URL below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edulearn

PORT=4000
JWT_SECRET=change-me-in-production-use-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Render/Neon: SSL is usually required — set PGSSLMODE=require or DATABASE_SSL=1
# PGSSLMODE=require
